# This file is managed by gitlab-ctl. Manual changes will be
# erased! To change the contents below, edit /etc/gitlab/gitlab.rb
# and run `sudo gitlab-ctl reconfigure`.
#
# OAK OpenBao reverse proxy – forwards traffic arriving at the configured
# external URL to the OpenBao service address in the Kubernetes cluster.

<% if @https && @redirect_http_to_https %>
server {
<% @listen_addresses.each do |listen_address| %>
  listen <%= listen_address %>:<%= @redirect_http_to_https_port %><% if @proxy_protocol %> proxy_protocol<% end %>;
<% end %>
  server_name <%= @fqdn %>;
  server_tokens off;

  access_log  <%= @log_directory %>/gitlab_openbao_access.log gitlab_access;
  error_log   <%= @log_directory %>/gitlab_openbao_error.log <%= @error_log_level %>;

  <% if @letsencrypt_enable %>
  location /.well-known/acme-challenge/ {
    root <%= @dir %>/www/;
  }
  <% end %>

  location / {
    <% if @listen_port != 443 %>
    return 301 https://<%= @fqdn %>:<%= @listen_port %>$request_uri;
    <% else %>
    return 301 https://<%= @fqdn %>$request_uri;
    <% end %>
  }
}
<% end %>

server {
<% @listen_addresses.each do |listen_address| %>
  listen <%= listen_address %>:<%= @listen_port %><% if @proxy_protocol %> proxy_protocol<% end %><% if @https %> ssl<% end %>;
<% end %>
  server_name <%= @fqdn %>;
  server_tokens off;

  disable_symlinks on;

<% if @https %>
  ssl_certificate <%= @ssl_certificate %>;
  ssl_certificate_key <%= @ssl_certificate_key %>;

  ssl_ciphers '<%= @ssl_ciphers %>';
  ssl_prefer_server_ciphers <%= @ssl_prefer_server_ciphers %>;
  ssl_protocols  <%= @ssl_protocols %>;
  ssl_session_cache  <%= @ssl_session_cache %>;
  ssl_session_timeout  <%= @ssl_session_timeout %>;
  ssl_session_tickets <%= @ssl_session_tickets %>;
  <% if @http2_enabled %>
  http2 on;
  <% end %>
  <% if @ssl_dhparam %>
  ssl_dhparam <%= @ssl_dhparam %>;
  <% end %>
  <% if @ssl_ecdh_curve %>
  ssl_ecdh_curve <%= @ssl_ecdh_curve %>;
  <% end %>
  <% Array(@ssl_conf_command).each do |command| %>
  ssl_conf_command <%= command %>;
  <% end %>
<% end %>

  <% if @real_ip_header %>
  real_ip_header <%= @real_ip_header %>;
  <% end %>
  <% if @real_ip_recursive %>
  real_ip_recursive <%= @real_ip_recursive %>;
  <% end %>
  <% @real_ip_trusted_addresses.each do |trusted_address| %>
  set_real_ip_from <%= trusted_address %>;
  <% end %>

  <% unless @hsts_max_age.nil? || @hsts_max_age <= 0 %>
  add_header Strict-Transport-Security "max-age=<%= @hsts_max_age -%>
<% if @hsts_include_subdomains %>; includeSubdomains<% end %>";
  <% end %>

  access_log  <%= @log_directory %>/gitlab_openbao_access.log gitlab_access;
  error_log   <%= @log_directory %>/gitlab_openbao_error.log <%= @error_log_level %>;

  <% if @letsencrypt_enable %>
  location /.well-known/acme-challenge/ {
    root <%= @dir %>/www/;
  }
  <% end %>

  location / {
    proxy_pass <%= @openbao_internal_url %>;
    proxy_http_version 1.1;

    proxy_set_header Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_read_timeout 60s;
    proxy_connect_timeout 5s;
    proxy_send_timeout 60s;

    proxy_redirect off;
    proxy_buffering off;
    proxy_cache off;
  }

  <%= @custom_gitlab_server_config %>
}
