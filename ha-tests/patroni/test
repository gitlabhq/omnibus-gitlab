#!/bin/bash

# -e: exit on error, -u: treat unset variables as errors, -o pipefail: catch failures in pipes
set -euo pipefail

DEFAULT_IMAGE="gitlab/gitlab-ee:nightly"
IMAGE="${IMAGE:-$DEFAULT_IMAGE}"
CLEANUP="${CLEANUP:-1}"

PASS=0
FAIL=1

cleanup() {
  local exitcode=$?
  [ "$CLEANUP" != "1" ] && { echo 'skipping cleanup'; exit $exitcode; }
  echo "exit code: $exitcode, running cleanup"
  docker compose down -v
  exit $exitcode
}
trap cleanup EXIT

log() { echo "[$(date -u +%H:%M:%S)] $*"; }
pass() { log "PASS: $*"; }
fail() { log "FAIL: $*" >&2; exit $FAIL; }

wait_for_healthy() {
  local service="$1"
  local max_attempts="${2:-60}"
  local attempt=0

  log "Waiting for $service to be healthy..."
  while ! docker compose ps "$service" | grep -q "healthy"; do
    attempt=$((attempt + 1))
    [ $attempt -ge $max_attempts ] && fail "$service did not become healthy after ${max_attempts}s"
    sleep 1
  done
  pass "$service is healthy"
}

assert_ctl_status() {
  local service="$1"
  local process="$2"

  if de_output=$(docker compose exec -T "$service" gitlab-ctl status "$process" 2>&1); then
    pass "$service: gitlab-ctl status $process"
  else
    fail "$service: gitlab-ctl status $process returned non-zero: $de_output"
  fi
}

assert_patroni_api() {
  local service="$1"
  local endpoint="$2"
  local expected_http="${3:-200}"

  local http_code
  http_code=$(docker compose exec -T "$service" \
    curl -s -o /dev/null -w "%{http_code}" "http://localhost:8008${endpoint}")

  if [ "$http_code" = "$expected_http" ]; then
    pass "$service: Patroni API ${endpoint} returned HTTP $http_code"
  else
    fail "$service: Patroni API ${endpoint} returned HTTP $http_code (expected $expected_http)"
  fi
}

pgbench_init() {
  local service="$1"
  log "Initialising pgbench dataset on $service..."
  # pgbench must run as the gitlab-psql OS user which owns the PostgreSQL socket
  docker compose exec -T "$service" \
    su - gitlab-psql -c "/opt/gitlab/embedded/bin/pgbench --initialize --scale=1 -h /var/opt/gitlab/postgresql gitlabhq_production" > /dev/null 2>&1
  pass "$service: pgbench dataset initialised"
}

assert_pgbench_rows() {
  local service="$1"
  local expected="${2:-100000}"

  local actual
  actual=$(docker compose exec -T "$service" \
    su - gitlab-psql -c "psql -h /var/opt/gitlab/postgresql gitlabhq_production -c 'SELECT count(*) FROM pgbench_accounts;' -t" 2>/dev/null | tr -d ' \n')

  if [ "$actual" = "$expected" ]; then
    pass "$service: pgbench_accounts has $actual rows"
  else
    fail "$service: pgbench_accounts has $actual rows (expected $expected)"
  fi
}

assert_consul_members() {
  local expected_count="$1"

  local member_count
  member_count=$(docker compose exec -T consul \
    /opt/gitlab/embedded/bin/consul members | grep -c "alive" || true)

  if [ "$member_count" -ge "$expected_count" ]; then
    pass "Consul has $member_count alive member(s) (expected >= $expected_count)"
  else
    fail "Consul has $member_count alive member(s) (expected >= $expected_count)"
  fi
}

wait_for_patroni_promotion() {
  local service="$1"
  local max_attempts="${2:-60}"
  local attempt=0

  log "Waiting for $service to be promoted to leader..."
  while true; do
    local http_code
    http_code=$(docker compose exec -T "$service" \
      curl -s -o /dev/null -w "%{http_code}" "http://localhost:8008/health" 2>/dev/null || echo "000")  # "000" on curl failure keeps the variable set for the comparison below
    [ "$http_code" = "200" ] && break
    attempt=$((attempt + 1))
    [ $attempt -ge $max_attempts ] && fail "$service was not promoted after ${max_attempts}s"
    sleep 1
  done
  pass "$service promoted to leader"
}

main() {
  cd "$(dirname "$0")"
  export IMAGE

  log "Starting Patroni HA smoke test with image: $IMAGE"

  log "--- Stage 1: Consul ---"
  docker compose up -d consul
  wait_for_healthy consul 60

  log "--- Stage 2: Postgres primary ---"
  docker compose up -d postgres-primary
  wait_for_healthy postgres-primary 120

  log "--- Stage 3: Postgres replica ---"
  docker compose up -d postgres-replica
  wait_for_healthy postgres-replica 120

  log "--- Stage 4: Seed data ---"
  pgbench_init postgres-primary
  assert_pgbench_rows postgres-primary

  log "--- Stage 5: Assertions ---"

  assert_ctl_status postgres-primary consul
  assert_ctl_status postgres-primary patroni

  assert_ctl_status postgres-replica consul
  assert_ctl_status postgres-replica patroni

  assert_patroni_api postgres-primary /health 200
  assert_patroni_api postgres-replica /replica 200

  assert_consul_members 3

  log "--- Stage 6: Failover ---"
  log "Stopping postgres-primary to trigger failover..."
  # stop (SIGTERM) triggers a graceful Patroni leader release — more realistic than kill
  docker compose stop postgres-primary
  wait_for_patroni_promotion postgres-replica 90
  assert_patroni_api postgres-replica /health 200
  assert_pgbench_rows postgres-replica

  log "--- All checks passed ---"
}

main
